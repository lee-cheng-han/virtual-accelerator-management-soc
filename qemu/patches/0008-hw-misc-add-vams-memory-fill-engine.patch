Subject: [PATCH] hw/misc: add VAMS memory-fill engine

Authorize MEM_FILL through the firmware command bridge and execute it through
PCI DMA. Read the fill byte before constructing the private destination buffer,
retain the existing transfer bound, and preserve directional DMA failures and
all-or-nothing completion accounting.

---
diff --git a/hw/misc/vams_pcie.c b/hw/misc/vams_pcie.c
--- a/hw/misc/vams_pcie.c
+++ b/hw/misc/vams_pcie.c
@@ -278,7 +278,8 @@ static uint16_t vams_pcie_validate_command(
         return VAMS_ERR_UNSUPPORTED_VERSION;
     }
     if (submission->opcode != VAMS_OP_NOP &&
-        submission->opcode != VAMS_OP_MEM_COPY) {
+        submission->opcode != VAMS_OP_MEM_COPY &&
+        submission->opcode != VAMS_OP_MEM_FILL) {
         return VAMS_ERR_INVALID_OPCODE;
     }
     if (submission->flags) {
@@ -316,6 +317,17 @@ static uint16_t vams_pcie_validate_command(
             return VAMS_ERR_INVALID_ADDRESS;
         }
     }
+    if (submission->opcode == VAMS_OP_MEM_FILL) {
+        if (!length || length > 0x01000000) {
+            return VAMS_ERR_INVALID_LENGTH;
+        }
+        if (vams_pcie_range_overflows(destination, length)) {
+            return VAMS_ERR_ADDRESS_OVERFLOW;
+        }
+        if (!source || !destination) {
+            return VAMS_ERR_INVALID_ADDRESS;
+        }
+    }
     return VAMS_ERR_NONE;
 }
 
@@ -349,7 +361,7 @@ static void vams_pcie_complete_dma_error(struct vams_completion *completion,
     completion->result_crc = 0;
 }
 
-static void vams_pcie_execute_mem_copy(
+static void vams_pcie_execute_payload(
     VamsPcieState *s, const struct vams_submission *submission,
     struct vams_completion *completion)
 {
@@ -359,7 +371,8 @@ static void vams_pcie_execute_mem_copy(
     MemTxResult result;
 
     if (le16_to_cpu(completion->status) != VAMS_STATUS_SUCCESS ||
-        submission->opcode != VAMS_OP_MEM_COPY) {
+        (submission->opcode != VAMS_OP_MEM_COPY &&
+         submission->opcode != VAMS_OP_MEM_FILL)) {
         return;
     }
     if (vams_pcie_validate_command(submission) != VAMS_ERR_NONE) {
@@ -373,12 +386,15 @@ static void vams_pcie_execute_mem_copy(
         return;
     }
     result = pci_dma_read(pdev, le64_to_cpu(submission->source_dma), buffer,
-                          length);
+                          submission->opcode == VAMS_OP_MEM_FILL ? 1 : length);
     if (result != MEMTX_OK) {
         vams_pcie_complete_dma_error(completion, VAMS_ERR_DMA_READ);
         g_free(buffer);
         return;
     }
+    if (submission->opcode == VAMS_OP_MEM_FILL) {
+        memset(buffer, buffer[0], length);
+    }
     result = pci_dma_write(pdev, le64_to_cpu(submission->destination_dma),
                            buffer, length);
     g_free(buffer);
@@ -419,7 +435,7 @@ static void vams_pcie_bridge_receive(void *opaque, const uint8_t *buf,
         return;
     }
     s->bridge_inflight = false;
-    vams_pcie_execute_mem_copy(
+    vams_pcie_execute_payload(
         s, &s->bridge_submission.command,
         (struct vams_completion *)s->bridge_completion);
     vams_pcie_publish_completion(
@@ -496,7 +512,7 @@ static void vams_pcie_process_sq(VamsPcieState *s)
         completion.device_timestamp = cpu_to_le64(
             qemu_clock_get_us(QEMU_CLOCK_VIRTUAL));
 
-        vams_pcie_execute_mem_copy(s, &submission, &completion);
+        vams_pcie_execute_payload(s, &submission, &completion);
 
         if (!vams_pcie_publish_completion(s, &completion)) {
             return;
