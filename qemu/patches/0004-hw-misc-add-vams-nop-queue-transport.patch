+static bool vams_pcie_valid_depth(uint32_t depth)
+{
+    return depth >= VAMS_QUEUE_MIN_DEPTH && depth <= VAMS_QUEUE_MAX_DEPTH &&
+           is_power_of_2(depth);
+}
+
+static bool vams_pcie_cq_full(const VamsPcieState *s)
+{
+    return s->cq_depth && ((s->cq_tail + 1) & (s->cq_depth - 1)) == s->cq_head;
+}
+
+static uint32_t vams_pcie_sq_status(const VamsPcieState *s)
+{
+    uint32_t status = 0;
+
+    if (s->sq_control & VAMS_QUEUE_ENABLE) {
+        status |= VAMS_QUEUE_STATUS_ENABLED;
+        if (s->sq_head == s->sq_tail) {
+            status |= VAMS_QUEUE_STATUS_EMPTY;
+        }
+        if (((s->sq_tail + 1) & (s->sq_depth - 1)) == s->sq_head) {
+            status |= VAMS_QUEUE_STATUS_FULL;
+        }
+    }
+    if (s->sq_error) {
+        status |= BIT(4);
+    }
+    return status;
+}
+
+static uint32_t vams_pcie_cq_status(const VamsPcieState *s)
+{
+    uint32_t status = 0;
+
+    if (s->cq_control & VAMS_QUEUE_ENABLE) {
+        status |= VAMS_QUEUE_STATUS_ENABLED;
+        if (s->cq_head == s->cq_tail) {
+            status |= VAMS_QUEUE_STATUS_EMPTY;
+        }
+        if (vams_pcie_cq_full(s)) {
+            status |= VAMS_QUEUE_STATUS_FULL;
+        }
+    }
+    if (s->cq_error) {
+        status |= BIT(4);
+    }
+    return status;
+}
+
+static void vams_pcie_update_queue_ready(VamsPcieState *s)
+{
+    if ((s->sq_control & VAMS_QUEUE_ENABLE) &&
+        (s->cq_control & VAMS_QUEUE_ENABLE)) {
+        s->device_status |= VAMS_STATUS_QUEUES_READY;
+    } else {
+        s->device_status &= ~VAMS_STATUS_QUEUES_READY;
+        s->device_control &= ~VAMS_CONTROL_ENABLE;
+    }
+}
+
+static void vams_pcie_queue_reset(VamsPcieState *s)
+{
+    s->device_control &= ~VAMS_CONTROL_ENABLE;
+    s->device_status &= ~VAMS_STATUS_QUEUES_READY;
+    s->sq_head = 0;
+    s->sq_tail = 0;
+    s->sq_control = 0;
+    s->sq_error = false;
+    s->cq_head = 0;
+    s->cq_tail = 0;
+    s->cq_control = 0;
+    s->cq_error = false;
+    s->intr_status &= ~VAMS_INTR_CQ;
+    msix_clr_pending(PCI_DEVICE(s), 0);
+    s->reset_generation++;
+}
+
+static uint16_t vams_pcie_validate_nop(const struct vams_submission *submission)
+{
+    uint32_t timeout_ms;
+
+    if (le16_to_cpu(submission->version) != VAMS_DESC_VERSION_1) {
+        return VAMS_ERR_UNSUPPORTED_VERSION;
+    }
+    if (submission->opcode != VAMS_OP_NOP) {
+        return VAMS_ERR_INVALID_OPCODE;
+    }
+    if (submission->flags) {
+        return VAMS_ERR_INVALID_FLAGS;
+    }
+    if (le32_to_cpu(submission->expected_crc) ||
+        le32_to_cpu(submission->reserved0) ||
+        le64_to_cpu(submission->reserved1) ||
+        le64_to_cpu(submission->reserved2)) {
+        return VAMS_ERR_RESERVED_NONZERO;
+    }
+    timeout_ms = le32_to_cpu(submission->timeout_ms);
+    if (timeout_ms > 60000) {
+        return VAMS_ERR_INVALID_TIMEOUT;
+    }
+    if (le32_to_cpu(submission->length)) {
+        return VAMS_ERR_INVALID_LENGTH;
+    }
+    if (le64_to_cpu(submission->source_dma) ||
+        le64_to_cpu(submission->destination_dma)) {
+        return VAMS_ERR_INVALID_ADDRESS;
+    }
+    return VAMS_ERR_NONE;
+}
+
+static void vams_pcie_process_sq(VamsPcieState *s)
+{
+    PCIDevice *pdev = PCI_DEVICE(s);
+
+    if (!(s->device_control & VAMS_CONTROL_ENABLE) ||
+        (s->device_control & VAMS_CONTROL_QUIESCE) ||
+        !(pci_get_word(pdev->config + PCI_COMMAND) & PCI_COMMAND_MASTER)) {
+        return;
+    }
+
+    while (s->sq_head != s->sq_tail && !vams_pcie_cq_full(s)) {
+        struct vams_submission submission;
+        struct vams_completion completion = { 0 };
+        uint16_t error_code;
+        dma_addr_t address;
+        MemTxResult result;
+
+        address = s->sq_base + (uint64_t)s->sq_head * VAMS_SUBMISSION_SIZE;
+        result = pci_dma_read(pdev, address, &submission, sizeof(submission));
+        if (result != MEMTX_OK) {
+            s->sq_error = true;
+            vams_pcie_set_error(s, VAMS_ERROR_DMA | VAMS_ERROR_QUEUE);
+            return;
+        }
+        s->sq_head = (s->sq_head + 1) & (s->sq_depth - 1);
+
+        error_code = vams_pcie_validate_nop(&submission);
+        completion.command_id = submission.command_id;
+        completion.status = cpu_to_le16(error_code == VAMS_ERR_NONE ?
+                                        VAMS_STATUS_SUCCESS :
+                                        VAMS_STATUS_INVALID);
+        completion.error_code = cpu_to_le16(error_code);
+        completion.user_cookie = submission.user_cookie;
+        completion.device_timestamp = cpu_to_le64(
+            qemu_clock_get_us(QEMU_CLOCK_VIRTUAL));
+
+        address = s->cq_base + (uint64_t)s->cq_tail * VAMS_COMPLETION_SIZE;
+        result = pci_dma_write(pdev, address, &completion, sizeof(completion));
+        if (result != MEMTX_OK) {
+            s->cq_error = true;
+            vams_pcie_set_error(s, VAMS_ERROR_DMA | VAMS_ERROR_QUEUE);
+            return;
+        }
+        s->cq_tail = (s->cq_tail + 1) & (s->cq_depth - 1);
+        vams_pcie_raise_interrupt(s, VAMS_INTR_CQ);
+    }
+}
