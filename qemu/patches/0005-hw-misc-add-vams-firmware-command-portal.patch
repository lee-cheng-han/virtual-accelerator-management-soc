     VAMS_SRAM_BASE = 0x80000000,
     VAMS_SRAM_SIZE = 0x00080000,
 };
@@ -113,6 +114,7 @@
     sysbus_realize_and_unref(SYS_BUS_DEVICE(mgmt), &error_fatal);
     sysbus_mmio_map(SYS_BUS_DEVICE(mgmt), 0, VAMS_MAILBOX_BASE);
     sysbus_mmio_map(SYS_BUS_DEVICE(mgmt), 1, VAMS_CONTROL_BASE);
